<!DOCTYPE html>
<html>
  <head>
    <title>CaffeineMonster</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <script src="https://cdn.tailwindcss.com"></script>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50 min-h-screen text-gray-900">
    <nav class="bg-white shadow-sm border-b border-gray-200">
      <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
        <div class="flex items-center space-x-4">
          <span class="text-lg font-bold text-indigo-600">CaffeineMonster</span>
          <% if current_user %>
            <%= link_to 'Users', users_path, class: 'text-gray-700 hover:text-indigo-600 font-medium' %>
            <%= link_to 'Teams', teams_path, class: 'text-gray-700 hover:text-indigo-600 font-medium' %>
          <% end %>
        </div>
        <div class="flex items-center space-x-4">
          <% if current_user %>
            <span class="text-sm text-gray-600">Logged in as <span class="font-medium"><%= current_user.email %></span></span>
            <%= link_to 'Log Out', logout_path, data: { turbo_method: :delete }, class: 'px-3 py-1.5 bg-red-500 text-white text-sm rounded-md hover:bg-red-600' %>
          <% else %>
            <%= link_to 'Log In', login_path, class: 'px-3 py-1.5 bg-indigo-600 text-white text-sm rounded-md hover:bg-indigo-700' %>
          <% end %>
        </div>
      </div>
    </nav>

    <main class="max-w-6xl mx-auto px-4 py-6">
      <% if flash[:notice] %>
        <div class="mb-4 p-4 rounded-md bg-green-50 border border-green-200 text-green-800"><%= flash[:notice] %></div>
      <% end %>
      <% if flash[:alert] %>
        <div class="mb-4 p-4 rounded-md bg-red-50 border border-red-200 text-red-800"><%= flash[:alert] %></div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>

<div class="max-w-xl">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">Editing user</h1>

  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
    <%= render "form", user: @user %>
  </div>

  <div class="mt-6 flex items-center space-x-4">
    <%= link_to "Show this user", @user, class: "text-indigo-600 hover:text-indigo-800 text-sm font-medium" %>
    <%= link_to "Back to users", users_path, class: "text-indigo-600 hover:text-indigo-800 text-sm font-medium" %>
  </div>
</div>

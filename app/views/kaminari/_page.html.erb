<li>
  <% if page.current? %>
    <span class="px-3 py-2 text-sm font-semibold 
      text-white bg-indigo-600 border border-indigo-600 rounded-xl"
      aria-current="page">
      <%= page %>
    </span>
  <% else %>
    <%= link_to page, url, remote: remote,
      class: "px-3 py-2 text-sm font-medium text-gray-700 
        bg-white border border-gray-300 hover:bg-indigo-50 
        hover:text-indigo-700 rounded-xl"
    %>
  <% end %>
</li>

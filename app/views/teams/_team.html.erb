<div id="<%= dom_id team %>" class="flex items-center space-x-3">
  <div class="w-10 h-10 rounded-lg bg-emerald-100 dark:bg-emerald-900 text-emerald-700 dark:text-emerald-300 flex items-center justify-center font-semibold">
    <%= team.name.to_s.first&.upcase || "?" %>
  </div>
  <div>
    <p class="text-sm text-gray-500 dark:text-gray-400">Name</p>
    <p class="font-semibold text-gray-900 dark:text-gray-100"><%= team.name %></p>
  </div>
</div>

<h1>Log In</h1>

<%= form_with url: sessions_path, method: :post do |f| %>
  <div>
    <%= f.label :email %>
    <%= f.email_field :email, required: true %>
  </div>

  <div>
    <%= f.label :password %>
    <%= f.password_field :password, required: true %>
  </div>

  <div>
    <%= f.submit 'Log In' %>
  </div>
<% end %>

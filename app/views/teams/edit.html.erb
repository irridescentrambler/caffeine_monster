<div class="max-w-xl">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">Editing team</h1>

  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
    <%= render "form", team: @team %>
  </div>

  <div class="mt-6 flex items-center space-x-4">
    <%= link_to "Show this team", @team, class: "text-indigo-600 hover:text-indigo-800 text-sm font-medium" %>
    <%= link_to "Back to teams", teams_path, class: "text-indigo-600 hover:text-indigo-800 text-sm font-medium" %>
  </div>
</div>

{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Rails Server",
      "runtimeExecutable": "bin/rails",
      "runtimeArgs": ["server", "-p", "3000", "-b", "0.0.0.0"],
      "port": 3000
    },
    {
      "name": "Docker: Full Stack",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up"],
      "port": 3000
    },
    {
      "name": "Docker: MySQL",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "db"],
      "port": 3307
    },
    {
      "name": "Docker: Redis",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "redis"],
      "port": 6379
    }
  ]
}

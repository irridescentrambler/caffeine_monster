<div class="max-w-xl">
  <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-6">Editing team</h1>

  <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-6">
    <%= render "form", team: @team %>
  </div>

  <div class="mt-6 flex items-center space-x-4">
    <%= link_to "Show this team", @team, class: "text-indigo-600 dark:text-indigo-400 hover:text-indigo-800 dark:hover:text-indigo-300 text-sm font-medium" %>
    <%= link_to "Back to teams", teams_path, class: "text-indigo-600 dark:text-indigo-400 hover:text-indigo-800 dark:hover:text-indigo-300 text-sm font-medium" %>
  </div>
</div>

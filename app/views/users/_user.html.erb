<div id="<%= dom_id user %>" class="space-y-2">
  <div class="flex items-center space-x-3">
    <div class="w-10 h-10 rounded-full bg-indigo-100 dark:bg-indigo-900 text-indigo-700 dark:text-indigo-300 flex items-center justify-center font-semibold">
      <%= user.name.to_s.first&.upcase || "?" %>
    </div>
    <div>
      <p class="text-sm text-gray-500 dark:text-gray-400">Name</p>
      <p class="font-semibold text-gray-900 dark:text-gray-100"><%= user.name %></p>
    </div>
  </div>
  <div>
    <p class="text-sm text-gray-500 dark:text-gray-400">Email</p>
    <p class="text-gray-800 dark:text-gray-200"><%= user.email %></p>
  </div>
</div>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Teams</h1>
  <%=
    link_to "New team", new_team_path,
      class: "px-4 py-2 bg-indigo-600 text-white rounded-md hover:bg-indigo-700 font-medium"
  %>
</div>

<div id="teams" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
  <% @teams.each do |team| %>
    <div
      class="bg-white rounded-lg shadow-sm border border-gray-200
        p-5 hover:shadow-md transition-shadow"
    >
      <%= render team %>
      <div class="mt-4 pt-4 border-t border-gray-100">
        <%=
          link_to "Show this team",
          team, class: "text-indigo-600 hover:text-indigo-800 text-sm font-medium"
        %>
      </div>
    </div>
  <% end %>
</div>

<div class="mt-8 flex flex-col items-center space-y-2">
  <%= paginate @teams %>
  <p class="text-sm text-gray-500">
    <%= page_entries_info @teams %>
  </p>
</div>
